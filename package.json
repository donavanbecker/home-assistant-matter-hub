{
  "name": "@home-assistant-matter-hub/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "cleanup": "pnpm -r run cleanup && pnpm run cleanup:root",
    "cleanup:root": "npx rimraf node_modules",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "pretest": "pnpm run build:minimum",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build",
    "build:minimum": "pnpm --filter @home-assistant-matter-hub/common run build",
    "build:app": "pnpm --filter './packages/*' run build",
    "preserve": "pnpm run build:minimum",
    "serve": "pnpm -r --parallel run serve",
    "start": "pnpm run serve",
    "preproduction": "pnpm run build:app",
    "production": "pnpm --filter home-assistant-matter-hub run start",
    "check-updates": "npx npm-check-updates --workspaces --root -u",
    "release": "semantic-release",
    "release:version": "pnpm version --workspaces --no-workspaces-update --no-git-tag-version --allow-same-version",
    "release:pack": "pnpm --filter home-assistant-matter-hub run bundle",
    "release:publish": "pnpm publish apps/home-assistant-matter-hub/package.tgz --provenance --no-git-checks --access public --loglevel verbose --tag ${CHANNEL:-latest}"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs"
  ],
  "pnpm": {
    "overrides": {
      "path-to-regexp@<8.4.0": "^8.4.0",
      "minimatch@<5.1.8": "5.1.8",
      "minimatch@<9.0.7": "9.0.7"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.3",
    "@dotenvx/dotenvx": "^1.61.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.30",
    "@swc/helpers": "~0.5.21",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "esbuild": "^0.28.0",
    "esbuild-plugin-noexternal": "^0.1.6",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "npm-check-updates": "^19.6.6",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
